# ─────────────────────────────────────────────
#  Patrimônio Inteligente — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=3000

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/patrimonio_inteligente?schema=public"

# JWT — use uma string aleatória longa (mínimo 64 caracteres)
JWT_SECRET=troque_por_uma_string_secreta_longa_e_aleatoria_aqui
JWT_EXPIRES_IN=8h

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000

# Upload de arquivos
UPLOAD_MAX_SIZE_MB=10
